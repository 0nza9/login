# Copy this file to .env and fill in the values.
# Generate a secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=
# Locally: must match the dev server port (see server.port in vite.config.ts).
# In production (Vercel): set this to your deployed URL, e.g.
#   BETTER_AUTH_URL=https://onzaaa.vercel.app
BETTER_AUTH_URL=http://localhost:5175

# Optional extra allowed origins (comma-separated) to avoid "Invalid origin".
# Useful for Vercel preview deployments (unique URL each time):
#   TRUSTED_ORIGINS=https://onzaaa.vercel.app,https://*.vercel.app
# TRUSTED_ORIGINS=

# Production database (Turso/libSQL). Leave unset locally to use file:sqlite.db.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Resend — sends password-reset emails. Get a key at https://resend.com.
RESEND_API_KEY=
# Must be an address on a domain verified in Resend. The default
# onboarding@resend.dev only delivers to your own Resend account email.
EMAIL_FROM=onboarding@resend.dev
